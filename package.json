{
  "name": "guido",
  "author": "Gui Ruggiero",
  "homepage": "https://guiruggiero.com/",
  "version": "0.1",
  "type": "module",
  "main": "app.js",
  "dependencies": {
    "@google/genai": "^2.9.0",
    "@langfuse/client": "^5.5.3",
    "@langfuse/otel": "^5.5.3",
    "@langfuse/tracing": "^5.0.1",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@sentry/node": "^10.59.0",
    "@vonage/jwt": "^1.14.0",
    "@vonage/messages": "^1.24.0",
    "@vonage/server-sdk": "^3.27.0",
    "axios": "^1.18.0",
    "axios-retry": "^4.5.0",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "mongodb": "^7.3.0",
    "sanitize-html": "^2.17.5"
  },
  "githubDependencies": {
    "esbuild": "",
    "terser": ""
  },
  "globalDependencies": {
    "@infisical/cli": ""
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint": "^10.5.0",
    "eslint-plugin-yml": "^3.4.0",
    "globals": "^17.6.0",
    "nodemon": "^3.1.14"
  },
  "nodemonConfig": {
    "ext": "js",
    "ignore": [
      "**/.github/**",
      "**/references/**",
      "**/eslint.config.js"
    ],
    "delay": 600000
  },
  "scripts": {
    "lint": "eslint .",
    "lint-fix": "eslint . --fix",
    "dev": "infisical run -- nodemon --import ./src/startup.js app.js",
    "tunnel": "ngrok start guido",
    "build": "esbuild app.js --bundle --format=esm --platform=node --packages=external --minify --sourcemap --outfile=dist/app.js",
    "minify": "terser ./src/startup.js --module --compress --mangle --source-map \"filename='./src/startup.js.map',url='startup.js.map'\" -o ./src/startup.js",
    "start": "infisical run -- node --import ./src/startup.js dist/app.js",
    "monitor": "htop --sort-key=PERCENT_MEM --tree --user",
    "prompt-pull": "infisical run -- node scripts/promptSync.js pull",
    "prompt-push": "infisical run -- node scripts/promptSync.js push"
  }
}
